---
const WORDS = [
  'Builder',
  'Product Thinker',
  'Community Leader',
  'Designer',
  'Writer',
  'Momentum'
]

const ASTERISK = `<svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M24 5 V43 M7 14 L41 34 M41 14 L7 34" stroke="currentColor" stroke-width="3.5" stroke-linecap="round"/></svg>`
---

<aside
  id='marquee-strip'
  class='relative -mx-12 mt-8 overflow-hidden border-y border-white/5 py-5 max-sm:-mx-4'
  aria-label='Roles and interests'
>
  <div class='marquee-row flex w-max items-center will-change-transform'>
    {
      [0, 1].map((copy) => (
        <div
          class='flex shrink-0 items-center'
          aria-hidden={copy === 1 ? 'true' : undefined}
        >
          {WORDS.map((word, index) => (
            <>
              <span
                class:list={[
                  'whitespace-nowrap px-8 font-serif text-2xl leading-none sm:text-3xl',
                  index % 2 === 0
                    ? 'font-medium text-zinc-200'
                    : 'font-light italic text-zinc-500'
                ]}
              >
                {word}
              </span>
              <span
                class='inline-block size-4 shrink-0 text-accent-500 sm:size-5 [&>svg]:h-full [&>svg]:w-auto'
                set:html={ASTERISK}
              />
            </>
          ))}
        </div>
      ))
    }
  </div>
</aside>

<script>
  import { gsap } from 'gsap'
  import { ScrollTrigger } from 'gsap/ScrollTrigger'

  gsap.registerPlugin(ScrollTrigger)

  let marqueeTween: gsap.core.Tween | undefined

  function initMarquee() {
    const strip = document.getElementById('marquee-strip')
    const row = strip?.querySelector<HTMLElement>('.marquee-row')
    if (!strip || !row) return
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return

    marqueeTween = gsap.to(row, {
      xPercent: -50,
      ease: 'none',
      duration: 28,
      repeat: -1
    })

    // Scroll velocity drives speed and direction; skew adds a little drag
    ScrollTrigger.create({
      onUpdate(self) {
        const velocity = gsap.utils.clamp(-3000, 3000, self.getVelocity())
        const direction = velocity < -60 ? -1 : 1
        const speed = gsap.utils.clamp(1, 5, 1 + Math.abs(velocity) / 700)

        gsap.to(marqueeTween!, {
          timeScale: speed * direction,
          duration: 0.4,
          overwrite: true
        })
        gsap.to(row, {
          skewX: gsap.utils.clamp(-8, 8, velocity / 300),
          duration: 0.4,
          overwrite: 'auto'
        })
      }
    })
  }

  document.addEventListener('astro:page-load', initMarquee)
  document.addEventListener('astro:before-swap', () => {
    marqueeTween?.kill()
    marqueeTween = undefined
  })
</script>
